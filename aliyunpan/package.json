{
  "name": "boxplayer",
  "description": "BoxPlayer",
  "version": "5.0.8",
  "main": "dist/electron/main/index.js",
  "packageManager": "pnpm@10.32.1",
  "author": {
    "name": "gaozhangmin",
    "email": "gaozhangmin@gmail.com"
  },
  "homepage": "https://github.com/gaozhangmin/boxplayer",
  "license": "GPL-3.0",
  "bin": {
    "clouddrive-cli": "scripts/clouddrive-cli.mjs",
    "clouddrive-mcp": "scripts/clouddrive-mcp.mjs"
  },
  "scripts": {
    "secrets:generate": "node scripts/generate-secrets.mjs --mode=local",
    "predev": "node scripts/generate-secrets.mjs --mode=local",
    "dev": "vite",
    "prebuild": "node scripts/generate-secrets.mjs --mode=local",
    "build": "node version.mjs && vue-tsc --noEmit && vite build",
    "build:version": "node version.mjs",
    "build:electron": "pnpm run build && electron-builder",
    "build:test": "pnpm run build && electron-builder --dir",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:mac:signed": "pnpm run build && CSC_IDENTITY_AUTO_DISCOVERY=true electron-builder --mac",
    "build:linux": "pnpm run build && node build-linux.mjs",
    "build:windows": "pnpm run build && electron-builder --win",
    "build:all": "node build-all.mjs",
    "build:clouddrive-cli": "node scripts/build-clouddrive-cli-package.mjs",
    "pretest": "node scripts/generate-secrets.mjs --mode=local",
    "test": "vitest run electron/main/aria/__tests__ src/down/motrix-integration src/utils/__tests__/aria2EnginePolicy.test.ts src/utils/__tests__/aria2Rpc.test.ts",
    "test:mpv-integration": "BOXPLAYER_MPV_INTEGRATION=1 vitest run src/utils/__tests__/mpvRuntime.integration.test.ts",
    "test:clouddrive-cli": "vitest run clouddrive-cli/__tests__"
  },
  "engines": {
    "node": ">=22.12.0"
  },
