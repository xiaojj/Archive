{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "importHelpers": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "baseUrl": "./",
    "strict": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "paths": {
      "@shared/*": ["shared/*"],
      "@main/*":   ["electron/main/*"]
    }
  },
  "include": [
    "src",
    "shared"
  ],
  "exclude": [
    "shared/__tests__"
  ]
}
