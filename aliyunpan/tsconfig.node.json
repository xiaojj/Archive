{
  "compilerOptions": {
    "target": "ESNext",
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "preserve",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./",
    "paths": {
      "@shared/*": ["shared/*"],
      "@main/*":   ["electron/main/*"]
    },
    "types": [
      "vite-plugin-electron/electron-env"
    ]
  },
  "include": ["package.json", "electron", "shared"],
  "exclude": ["shared/__tests__", "shared/types/reedy.ts", "shared/types/mediaAcquisition.ts", "shared/utils/vector.ts"]
}
