 /**
+ * struct ppe_ft_pppoe - A refcounted PPPoE session of an egress port.
+ * @ref: Reference count of the session.
+ * @sid: PPPoE session ID.
+ * @port: PPE port the session runs on.
+ *
+ * A session owns the PPPoE session table entry and the L3 interface
+ * of its slot index (past the per-port L3 interfaces): the interface
+ * encapsulates on egress and terminates on ingress, the session table
+ * entry assigns the ingress packets of the session to it.
+ */
+struct ppe_ft_pppoe {
+	struct ppe_ft_ref ref;
+	u16 sid;
+	u8 port;
+};
+
+static_assert(offsetof(struct ppe_ft_pppoe, ref) == 0);
+
+#define PPE_FT_PPPOE_SESSIONS	8
+
+/**
  * struct ppe_ft_flow - An offloaded flow.
  * @node: Hash table node, keyed by the flow cookie.
  * @cookie: Flow cookie of the rule.
@@ -79,6 +101,7 @@ static_assert(offsetof(struct ppe_ft_pub
  * @nexthop: Next hop index of the flow.
  * @my_mac: Router MAC slot held by the flow, negative when none.
  * @pub_ip: Public IP slot held by the flow, negative when none.
+ * @pppoe: PPPoE session slot held by the flow, negative when none.
  * @packets: Hit packet count at the last stats read.
  * @bytes: Hit byte count at the last stats read.
  */
@@ -90,6 +113,7 @@ struct ppe_ft_flow {
 	u16 nexthop;
 	int my_mac;
 	int pub_ip;
+	int pppoe;
 	u32 packets;
 	u64 bytes;
 };
@@ -118,6 +142,7 @@ struct ppe_ft_host {
  * @nexthop_used: Allocation bitmap of the next hop entries.
  * @my_macs: Refcounted router MAC slots.
  * @pub_ips: Refcounted public IP slots.
+ * @pppoe: Refcounted PPPoE session slots.
  * @block_cb_list: Flow block callbacks bound to the PPE ports.
  * @hosts: Refcount of the flows sharing a destination host entry.
  */
@@ -129,6 +154,7 @@ struct ppe_flowtable {
 	DECLARE_BITMAP(nexthop_used, PPE_NEXTHOP_TBL_ENTRIES);
 	struct ppe_ft_my_mac my_macs[PPE_MY_MAC_TBL_ENTRIES];
 	struct ppe_ft_pub_ip pub_ips[PPE_PUB_IP_TBL_ENTRIES];
+	struct ppe_ft_pppoe pppoe[PPE_FT_PPPOE_SESSIONS];
 	struct list_head block_cb_list;
 };
 
@@ -152,6 +178,7 @@ struct ppe_ft_data {
 	__be32 dip;
 	__be16 sport;
 	__be16 dport;
+	int pppoe_sid;
 };
 
 static void ppe_ft_mangle_eth(const struct flow_action_entry *act, void *eth)
@@ -345,6 +372,58 @@ static void ppe_ft_pub_ip_put(struct ppe
 	ppe_ft_ref_put(ft->pub_ips, sizeof(*ft->pub_ips), index);
 }
 
+/* The reserved L3 interfaces are allocated in regions past the
+ * per-port ones, each region based at the end of the one before it;
+ * ppe_flowtable_setup() checks the layout fits the interface tables.
+ * A PPPoE session slot owns one interface of the first region.
+ */
+static int ppe_ft_pppoe_l3_if(struct ppe_flowtable *ft, int index)
+{
+	return ft->ppe_dev->num_ports + index;
+}
+
+/* Get a refcounted PPPoE session slot of (port, session ID),
+ * programming its session table entry on first use. Must be called
+ * with the flowtable lock held.
+ */
+static bool ppe_ft_pppoe_match(const void *entry, const void *key)
+{
+	const struct ppe_ft_pppoe *session = entry, *want = key;
+
+	return session->sid == want->sid && session->port == want->port;
+}
+
+static int ppe_ft_pppoe_get(struct ppe_flowtable *ft, int port, u16 sid)
+{
+	struct ppe_ft_pppoe want = { .sid = sid, .port = port };
+	bool is_new;
+	int i, ret;
+
+	i = ppe_ft_ref_get(ft->pppoe, sizeof(*ft->pppoe),
+			   PPE_FT_PPPOE_SESSIONS, ppe_ft_pppoe_match,
+			   &want, &is_new);
+	if (i < 0 || !is_new)
+		return i;
+
+	ret = ppe_pppoe_session_set(ft->ppe_dev, i, port, sid,
+				    ppe_ft_pppoe_l3_if(ft, i));
+	if (ret)
+		return ret;
+
+	want.ref.refcnt = 1;
+	ft->pppoe[i] = want;
+
+	return i;
+}
+
+static void ppe_ft_pppoe_put(struct ppe_flowtable *ft, int index)
+{
+	if (!ppe_ft_ref_put(ft->pppoe, sizeof(*ft->pppoe), index))
+		return;
+
+	ppe_pppoe_session_set(ft->ppe_dev, index, -1, 0, 0);
+}
+
 /* Hash key of a flow's destination IP for the host refcount table. */
 static u32 ppe_ft_host_key(const struct ppe_flow_entry *flow)
 {
@@ -458,8 +537,23 @@ static int ppe_ft_flow_replace(struct pp
 	    !flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_IPV6_ADDRS))
 		return -EOPNOTSUPP;
 
-	/* VLAN-tagged ingress is not translated to a flow key yet. */
-	if (flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_VLAN))
+	/* Match keys outside the supported set must reject the rule,
+	 * not be skipped: VLAN-tagged ingress is not translated to a
+	 * flow key yet, and a tunnel route arrives as ENC_* keys,
+	 * which offloaded as a plain routed flow would transmit the
+	 * packets unencapsulated. The TCP flags key is a knowing
+	 * exception: the hardware forwards FIN/RST packets instead of
+	 * punting them, which only delays the flow teardown until the
+	 * flow idles out.
+	 */
+	if (rule->match.dissector->used_keys &
+	    ~(BIT_ULL(FLOW_DISSECTOR_KEY_META) |
+	      BIT_ULL(FLOW_DISSECTOR_KEY_CONTROL) |
+	      BIT_ULL(FLOW_DISSECTOR_KEY_BASIC) |
+	      BIT_ULL(FLOW_DISSECTOR_KEY_IPV4_ADDRS) |
+	      BIT_ULL(FLOW_DISSECTOR_KEY_IPV6_ADDRS) |
+	      BIT_ULL(FLOW_DISSECTOR_KEY_TCP) |
+	      BIT_ULL(FLOW_DISSECTOR_KEY_PORTS)))
 		return -EOPNOTSUPP;
 
 	flow = kzalloc(sizeof(*flow), GFP_KERNEL);
@@ -469,7 +563,9 @@ static int ppe_ft_flow_replace(struct pp
 	flow->cookie = f->cookie;
 	flow->my_mac = -1;
 	flow->pub_ip = -1;
+	flow->pppoe = -1;
 	nh.vid = -1;
+	data.pppoe_sid = -1;
 
 	{
 		struct flow_match_basic match;
@@ -565,6 +661,9 @@ static int ppe_ft_flow_replace(struct pp
 			}
 			nh.vid = act->vlan.vid;
 			break;
+		case FLOW_ACTION_PPPOE_PUSH:
+			data.pppoe_sid = act->pppoe.sid;
+			break;
 		case FLOW_ACTION_CSUM:
 			break;
 		default:
@@ -579,6 +678,14 @@ static int ppe_ft_flow_replace(struct pp
 		goto err_free;
 	}
 
+	/* The PPPoE L3 interface carries the session ID, so it needs
+	 * the source MAC rewrite of the rule to be complete.
+	 */
+	if (data.pppoe_sid >= 0 && is_zero_ether_addr(data.eth.src)) {
+		ret = -EOPNOTSUPP;
+		goto err_free;
+	}
+
 	port_priv = netdev_priv(odev);
 	nh.port = port_priv->ppe_port->port_id;
 	nh.l3_if = nh.port;
@@ -627,25 +734,46 @@ static int ppe_ft_flow_replace(struct pp
 		flow->entry.fwd_type = PPE_FLOW_FWD_TYPE_ROUTE;
 	}
 
+	/* A PPPoE push routes the flow through the L3 interface of its
+	 * session, which encapsulates on egress; the session table
+	 * entry of the slot terminates the reverse direction, whose
+	 * rule arrives as a plain flow of the inner tuple.
+	 */
+	if (data.pppoe_sid >= 0) {
+		flow->pppoe = ppe_ft_pppoe_get(ft, nh.port, data.pppoe_sid);
+		if (flow->pppoe < 0) {
+			ret = flow->pppoe;
+			goto err_pub_ip;
+		}
+		nh.l3_if = ppe_ft_pppoe_l3_if(ft, flow->pppoe);
+	}
+
 	/* The source MAC of this direction is the router MAC the
-	 * reverse direction ingresses on; the egress L3 interface of
-	 * the port provides the rewrite.
+	 * reverse direction ingresses on; the egress L3 interface
+	 * provides the rewrite.
 	 */
 	if (!is_zero_ether_addr(data.eth.src)) {
 		flow->my_mac = ppe_ft_my_mac_get(ft, data.eth.src);
 		if (flow->my_mac < 0) {
 			ret = flow->my_mac;
-			goto err_pub_ip;
+			goto err_pppoe;
 		}
 
 		ret = ppe_l3_if_set(ft->ppe_dev, nh.l3_if, data.eth.src,
-				    odev->mtu);
+				    odev->mtu, data.pppoe_sid);
 		if (ret)
 			goto err_my_mac;
 
-		ret = ppe_port_l3_if_set(ft->ppe_dev, nh.port, nh.l3_if);
-		if (ret)
-			goto err_my_mac;
+		/* The port binding classifies plain ingress on the
+		 * port; PPPoE ingress resolves its L3 interface
+		 * through the session table instead.
+		 */
+		if (data.pppoe_sid < 0) {
+			ret = ppe_port_l3_if_set(ft->ppe_dev, nh.port,
+						 nh.l3_if);
+			if (ret)
+				goto err_my_mac;
+		}
 	}
 
 	nexthop = find_first_zero_bit(ft->nexthop_used,
@@ -694,6 +822,8 @@ err_host:
 	ppe_ft_host_put(ft, &flow->entry);
 err_my_mac:
 	ppe_ft_my_mac_put(ft, flow->my_mac);
+err_pppoe:
+	ppe_ft_pppoe_put(ft, flow->pppoe);
 err_pub_ip:
 	ppe_ft_pub_ip_put(ft, flow->pub_ip);
 err_unlock:
@@ -722,6 +852,7 @@ static int ppe_ft_flow_destroy(struct pp
 	if (ppe_ft_flow_hw_del(ft, flow, ppe_ft_host_put(ft, &flow->entry))) {
 		clear_bit(flow->nexthop, ft->nexthop_used);
 		ppe_ft_my_mac_put(ft, flow->my_mac);
+		ppe_ft_pppoe_put(ft, flow->pppoe);
 		ppe_ft_pub_ip_put(ft, flow->pub_ip);
 	}
 
@@ -854,6 +985,17 @@ int ppe_flowtable_setup(struct ppe_devic
 		return -ENOMEM;
 
 	ft->ppe_dev = ppe_dev;
+
+	/* The reserved L3 interface regions have compile-time sizes on
+	 * a runtime base (the port count); refuse a layout that would
+	 * overrun the interface tables.
+	 */
+	if (WARN_ON(ppe_ft_pppoe_l3_if(ft, PPE_FT_PPPOE_SESSIONS) >
+		    PPE_IN_L3_IF_TBL_ENTRIES)) {
+		kfree(ft);
+		return -ERANGE;
+	}
+
 	mutex_init(&ft->lock);
 	INIT_LIST_HEAD(&ft->block_cb_list);
 
