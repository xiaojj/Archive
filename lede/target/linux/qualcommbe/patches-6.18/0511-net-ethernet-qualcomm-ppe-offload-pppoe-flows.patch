+/* PPPoE session table of the tunnel lookup block. An entry matches
+ * PPPoE-encapsulated unicast or multicast ingress on the ports of its
+ * bitmap by session ID, optionally also by the source (server) MAC,
+ * and assigns the ingress L3 interface, which terminates the session
+ * when its PPPoE flag is set. The four register arrays of an entry
+ * share the index.
+ */
+#define PPE_PPPOE_SESSION_ADDR			0x306800
+#define PPE_PPPOE_SESSION_ENTRIES		64
+#define PPE_PPPOE_SESSION_INC			8
+#define PPE_PPPOE_SESSION_SESSION_ID		GENMASK(15, 0)
+#define PPE_PPPOE_SESSION_PORT_BITMAP		GENMASK(23, 16)
+#define PPE_PPPOE_SESSION_PORT_TYPE		GENMASK(25, 24)
+
+#define PPE_PPPOE_SESSION_EXT_ADDR		0x306a00
+#define PPE_PPPOE_SESSION_EXT_INC		4
+#define PPE_PPPOE_SESSION_EXT_MC_VALID		BIT(0)
+#define PPE_PPPOE_SESSION_EXT_UC_VALID		BIT(1)
+#define PPE_PPPOE_SESSION_EXT_SMAC_VALID	BIT(2)
+#define PPE_PPPOE_SESSION_EXT_SMAC_HI		GENMASK(31, 16)
+
+#define PPE_PPPOE_SESSION_EXT1_ADDR		0x306c00
+#define PPE_PPPOE_SESSION_EXT1_INC		4
+
+#define PPE_PPPOE_SESSION_EXT2_ADDR		0x306e00
+#define PPE_PPPOE_SESSION_EXT2_INC		4
+#define PPE_PPPOE_SESSION_EXT2_TL_L3_IF		GENMASK(6, 0)
+#define PPE_PPPOE_SESSION_EXT2_TL_L3_IF_VALID	BIT(7)
+#define PPE_PPPOE_SESSION_EXT2_L3_IF		GENMASK(15, 8)
+#define PPE_PPPOE_SESSION_EXT2_L3_IF_VALID	BIT(16)
+
 /* Per-flow hit counters, indexed like the flow table. */
 #define PPE_FLOW_CNT_TBL_ADDR			0x120000
 #define PPE_FLOW_CNT_TBL_ENTRIES		4096
