 #define PPE_EG_L3_IF_W1_MAC_ADDR_HI		GENMASK(15, 0)
+#define PPE_EG_L3_IF_W1_SESSION_ID		GENMASK(31, 16)
+#define PPE_EG_L3_IF_W2_PPPOE_EN		BIT(0)
