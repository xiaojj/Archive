 int ppe_port_vsi_set(struct ppe_device *ppe_dev, int port, int vsi);
 int ppe_vsi_eg_mode_set(struct ppe_device *ppe_dev, int vsi, u32 port_modes);
 int ppe_port_bridge_txmac_set(struct ppe_device *ppe_dev, int port,
 			      bool enable);
+int ppe_port_bridge_learning_set(struct ppe_device *ppe_dev, int port,
+				 bool enable);
 int ppe_port_stp_state_set(struct ppe_device *ppe_dev, int port,
 			   enum ppe_stp_state state);
 int ppe_fdb_entry_add(struct ppe_device *ppe_dev,
