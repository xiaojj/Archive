--- a/drivers/net/ethernet/qualcomm/ppe/ppe_regs.h
+++ b/drivers/net/ethernet/qualcomm/ppe/ppe_regs.h
@@ -454,6 +454,19 @@
 #define PPE_FDB_DST_INFO_TYPE_PORT_BITMAP	3
 #define PPE_FDB_DST_INFO_VALUE			GENMASK(11, 0)
 
+/* Per-virtual-port L2 configuration. A virtual port (64..255) binds a
+ * non-PPE net device; its entry carries the physical port that backs the
+ * VP and, for a host-terminated VP, is marked active.
+ */
+#define PPE_L2_VP_PORT_TBL_ADDR			0x98000
+#define PPE_L2_VP_PORT_TBL_ENTRIES		256
+#define PPE_L2_VP_PORT_TBL_INC			0x10
+#define PPE_L2_VP_PORT_W0_INVALID_VSI_FWD_EN	BIT(0)
+#define PPE_L2_VP_PORT_W0_PROMISC_EN		BIT(1)
+#define PPE_L2_VP_PORT_W0_PHYSICAL_PORT		GENMASK(12, 10)
+#define PPE_L2_VP_PORT_W1_VP_TYPE		BIT(29)
+#define PPE_L2_VP_PORT_W1_CONTEXT_ACTIVE	BIT(30)
+
 /* A static FDB entry has the maximum age value, which the aging process
  * never decrements. Dynamic entries are learned with PPE_FDB_HIT_AGE_FRESH,
  * to which a source address hit also refreshes them, so knocking an entry
--- /dev/null
+++ b/drivers/net/ethernet/qualcomm/ppe/ppe_vp.c
@@ -0,0 +1,245 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Copyright (c) 2026 Kenneth Kasilag <kenneth@kasilag.me>
+ */
+
+/* Virtual port offload for non-PPE net devices (wireless VAPs).
+ *
+ * A virtual port (VP) is a PPE port number past the physical ones,
+ * bound to a net device the PPE cannot reach directly. The L3 flow
+ * engine forwards a matched flow to the VP; the VP's L2_VP_PORT_TBL
+ * entry points its physical port at the CPU and its unicast queue at
+ * the CPU port's queue, so the packet lands on an EDMA ring already
+ * NAT'd and rewritten, and the EDMA receive path transmits it out the
+ * bound device (edma_rx.c). Only the wired->wireless direction is
+ * offloaded; the reverse stays on the software path (README.offload).
+ *
+ * The address of a wireless station is owned by the software bridge,
+ * so a VP does no learning of its own - the same assisted-learning
+ * split the rest of the series uses for foreign ports.
+ */
+
+#include <linux/bitfield.h>
+#include <linux/kernel.h>
+#include <linux/mutex.h>
+#include <linux/netdevice.h>
+#include <linux/rcupdate.h>
+#include <linux/regmap.h>
+
+#include "edma.h"
+#include "ppe.h"
+#include "ppe_config.h"
+#include "ppe_flowtable.h"
+#include "ppe_regs.h"
+#include "ppe_vp.h"
+
+/* The PPE CPU port, whose queue the EDMA rings drain. */
+#define PPE_VP_CPU_PORT		0
+
+struct ppe_vp_slot {
+	struct net_device __rcu *dev;
+	int refcnt;
+};
+
+struct ppe_vp {
+	struct ppe_device *ppe_dev;
+	struct mutex lock;		/* serialises slot allocation */
+	struct ppe_vp_slot slots[PPE_VP_SLOTS];
+};
+
+/* Program or tear down the L2_VP_PORT_TBL entry and unicast queue map
+ * of a virtual port. The field set mirrors the vendor driver's
+ * ppe_drv_port_alloc() for a wireless virtual port.
+ */
+static int ppe_vp_hw_set(struct ppe_device *ppe_dev, int vp, bool active)
+{
+	struct ppe_queue_ucast_dest queue_dst = {};
+	int ret, res_start, res_end;
+	u32 tbl[4] = {};
+	u32 reg;
+
+	if (active) {
+		/* A wireless virtual port is routed, not bridged, so it has
+		 * no VSI and must forward on an invalid one; it accepts any
+		 * address, is backed by the CPU port, and is marked an
+		 * active VP. Learning stays off (the zeroed learn fields) -
+		 * the software bridge owns station addresses.
+		 */
+		tbl[0] = PPE_L2_VP_PORT_W0_INVALID_VSI_FWD_EN |
+			 PPE_L2_VP_PORT_W0_PROMISC_EN |
+			 FIELD_PREP(PPE_L2_VP_PORT_W0_PHYSICAL_PORT,
+				    PPE_VP_CPU_PORT);
+		tbl[1] = PPE_L2_VP_PORT_W1_VP_TYPE |
+			 PPE_L2_VP_PORT_W1_CONTEXT_ACTIVE;
+	}
+
+	reg = PPE_L2_VP_PORT_TBL_ADDR + PPE_L2_VP_PORT_TBL_INC * vp;
+	ret = regmap_bulk_write(ppe_dev->regmap, reg, tbl, ARRAY_SIZE(tbl));
+	if (ret)
+		return ret;
+
+	/* Point the VP's unicast queue at the CPU port's queue base, so a
+	 * packet forwarded to the VP is enqueued to the EDMA rings.
+	 */
+	ret = ppe_port_resource_get(ppe_dev, PPE_VP_CPU_PORT, PPE_RES_UCAST,
+				    &res_start, &res_end);
+	if (ret)
+		return ret;
+
+	queue_dst.dest_port = vp;
+
+	return ppe_queue_ucast_base_set(ppe_dev, queue_dst,
+					active ? res_start : 0,
+					EDMA_CPU_PORT_PROFILE_ID);
+}
+
+/**
+ * ppe_vp_get - Get a virtual port for a net device
+ * @ppe_dev: PPE device
+ * @dev: net device to bind
+ *
+ * Return the PPE port id of a virtual port bound to @dev, allocating
+ * and programming one on first use and refcounting shared use. Must be
+ * paired with ppe_vp_put().
+ *
+ * Return: PPE port id (>= PPE_VP_PORT_BASE) on success, negative error
+ * code on failure.
+ */
+int ppe_vp_get(struct ppe_device *ppe_dev, struct net_device *dev)
+{
+	struct ppe_vp *vp = ppe_dev->vp;
+	int free = -1, i, ret;
+
+	if (!vp)
+		return -EOPNOTSUPP;
+
+	mutex_lock(&vp->lock);
+
+	for (i = 0; i < PPE_VP_SLOTS; i++) {
+		if (rcu_access_pointer(vp->slots[i].dev) == dev) {
+			vp->slots[i].refcnt++;
+			mutex_unlock(&vp->lock);
+			return PPE_VP_PORT_BASE + i;
+		}
+		if (free < 0 && !rcu_access_pointer(vp->slots[i].dev) &&
+		    !vp->slots[i].refcnt)
+			free = i;
+	}
+
+	if (free < 0) {
+		mutex_unlock(&vp->lock);
+		return -ENOSPC;
+	}
+
+	ret = ppe_vp_hw_set(ppe_dev, PPE_VP_PORT_BASE + free, true);
+	if (ret) {
+		mutex_unlock(&vp->lock);
+		return ret;
+	}
+
+	vp->slots[free].refcnt = 1;
+	rcu_assign_pointer(vp->slots[free].dev, dev);
+	mutex_unlock(&vp->lock);
+
+	/* Seed the carrier state so a flow to a down VAP is not reported
+	 * as active by the flowtable's stuck-flow guard.
+	 */
+	ppe_flowtable_port_carrier(ppe_dev, PPE_VP_PORT_BASE + free,
+				   netif_carrier_ok(dev));
+
+	return PPE_VP_PORT_BASE + free;
+}
+
+/**
+ * ppe_vp_put - Release a virtual port
+ * @ppe_dev: PPE device
+ * @vp: PPE port id returned by ppe_vp_get()
+ *
+ * Drop a reference to a virtual port, tearing down its hardware entry
+ * on the last release.
+ */
+void ppe_vp_put(struct ppe_device *ppe_dev, int vp)
+{
+	struct ppe_vp *vpt = ppe_dev->vp;
+	int i = vp - PPE_VP_PORT_BASE;
+
+	if (!vpt || i < 0 || i >= PPE_VP_SLOTS)
+		return;
+
+	mutex_lock(&vpt->lock);
+
+	/* Drop a reference. The device may already have unregistered (dev NULL,
+	 * hardware already off); the slot stays reserved until its last flow
+	 * releases it, so its id is never reused underneath a flow that still
+	 * points at it.
+	 */
+	if (!vpt->slots[i].refcnt || --vpt->slots[i].refcnt) {
+		mutex_unlock(&vpt->lock);
+		return;
+	}
+
+	if (rcu_access_pointer(vpt->slots[i].dev)) {
+		ppe_vp_hw_set(ppe_dev, vp, false);
+		rcu_assign_pointer(vpt->slots[i].dev, NULL);
+	}
+	mutex_unlock(&vpt->lock);
+}
+
+/**
+ * ppe_vp_dev - Resolve a virtual port to its net device
+ * @ppe_dev: PPE device
+ * @vp: PPE port id of a virtual port
+ *
+ * Return: the bound net device, or NULL. Callers must be in an RCU
+ * read-side critical section and must not keep the pointer past it.
+ */
+struct net_device *ppe_vp_dev(struct ppe_device *ppe_dev, int vp)
+{
+	struct ppe_vp *vpt = ppe_dev->vp;
+	int i = vp - PPE_VP_PORT_BASE;
+
+	if (!vpt || i < 0 || i >= PPE_VP_SLOTS)
+		return NULL;
+
+	return rcu_dereference(vpt->slots[i].dev);
+}
+
+int ppe_vp_setup(struct ppe_device *ppe_dev)
+{
+	struct ppe_vp *vp;
+
+	/* Virtual ports are an APPE feature; nothing to do without them. */
+	if (!ppe_dev->variant->has_vports)
+		return 0;
+
+	vp = devm_kzalloc(ppe_dev->dev, sizeof(*vp), GFP_KERNEL);
+	if (!vp)
+		return -ENOMEM;
+
+	vp->ppe_dev = ppe_dev;
+	mutex_init(&vp->lock);
+	ppe_dev->vp = vp;
+
+	return 0;
+}
+
+void ppe_vp_teardown(struct ppe_device *ppe_dev)
+{
+	struct ppe_vp *vp = ppe_dev->vp;
+	int i;
+
+	if (!vp)
+		return;
+
+	ppe_dev->vp = NULL;
+
+	for (i = 0; i < PPE_VP_SLOTS; i++) {
+		if (rcu_access_pointer(vp->slots[i].dev)) {
+			ppe_vp_hw_set(ppe_dev, PPE_VP_PORT_BASE + i, false);
+			rcu_assign_pointer(vp->slots[i].dev, NULL);
+		}
+	}
+
+	synchronize_rcu();
+	mutex_destroy(&vp->lock);
+}
--- /dev/null
+++ b/drivers/net/ethernet/qualcomm/ppe/ppe_vp.h
@@ -0,0 +1,31 @@
+/* SPDX-License-Identifier: GPL-2.0-only
+ *
+ * Copyright (c) 2026 Kenneth Kasilag <kenneth@kasilag.me>
+ */
+
+#ifndef __PPE_VP_H__
+#define __PPE_VP_H__
+
+struct ppe_device;
+struct net_device;
+
+/* Virtual ports bind a non-PPE net device (a wireless VAP) to a PPE
+ * port number, so the L3 flow engine can forward to it and the packet
+ * is delivered to the host on an EDMA ring for transmit out the bound
+ * device. See ppe_vp.c and README.offload.
+ *
+ * The slots map one-to-one onto a contiguous range of PPE port ids
+ * starting at PPE_VP_PORT_BASE, and onto the egress L3 interfaces the
+ * flowtable reserves past the physical, PPPoE and VLAN-uplink ones.
+ */
+#define PPE_VP_PORT_BASE	64
+#define PPE_VP_SLOTS		8
+
+int ppe_vp_setup(struct ppe_device *ppe_dev);
+void ppe_vp_teardown(struct ppe_device *ppe_dev);
+
+int ppe_vp_get(struct ppe_device *ppe_dev, struct net_device *dev);
+void ppe_vp_put(struct ppe_device *ppe_dev, int vp);
+struct net_device *ppe_vp_dev(struct ppe_device *ppe_dev, int vp);
+
+#endif
