From: Kenneth Kasilag <kenneth@kasilag.me>
Date: Sun, 05 Jul 2026 00:00:00 +0000
Subject: [PATCH] net: ethernet: qualcomm: ppe: offload TX flooding of VLAN-unaware bridges

Let VLAN-unaware bridges hand over a single copy of flooded packets
instead of cloning them per port: every replication target of such a
bridge receives the identical frame, so the EDMA can replicate it with
a bitmap destination in the transmit descriptor. VLAN-aware bridges
keep cloning in software, their egress tagging differs per port.

The bridge marks the single copy with offload_fwd_mark on transmit.
The EDMA picks the replication bitmap by the destination address
class of the frame from three per-port bitmaps maintained by the
bridge offload. A bitmap destination bypasses the spanning tree state
and the hardware multicast groups, so the bitmaps carry what those
checks would have enforced: ports outside the forwarding state are
excluded, and the multicast bitmap is the union of the flood members
and the offloaded group members, which can only over-deliver. The
bitmaps follow the port flags, the spanning tree changes, the group
membership and the snooping state.

Signed-off-by: Kenneth Kasilag <kenneth@kasilag.me>
---
--- a/drivers/net/ethernet/qualcomm/ppe/edma_port.h
+++ b/drivers/net/ethernet/qualcomm/ppe/edma_port.h
@@ -86,12 +86,23 @@ struct edma_port_pcpu_stats {
  * in the Rx path to mark received packets as hardware forwarded
  * @flags: Feature flags
  */
+/* Bridge flood bitmaps of the port for the TX forwarding offload,
+ * selected by the destination address class of the transmitted frame.
+ */
+enum edma_port_br_flood {
+	EDMA_PORT_FLOOD_UC,
+	EDMA_PORT_FLOOD_MC,
+	EDMA_PORT_FLOOD_BC,
+	EDMA_PORT_FLOOD_MAX
+};
+
 struct edma_port_priv {
 	struct ppe_port *ppe_port;
 	struct net_device *netdev;
 	struct edma_port_pcpu_stats pcpu_stats;
 	struct edma_txdesc_ring *txr_map[EDMA_PORT_MAX_CORE];
 	bool br_offload;
+	u32 br_flood[EDMA_PORT_FLOOD_MAX];
 	unsigned long flags;
 };
 
--- a/drivers/net/ethernet/qualcomm/ppe/edma_tx.c
+++ b/drivers/net/ethernet/qualcomm/ppe/edma_tx.c
@@ -7,6 +7,7 @@
  */
 
 #include <linux/dma-mapping.h>
+#include <linux/etherdevice.h>
 #include <linux/kernel.h>
 #include <linux/netdevice.h>
 #include <linux/platform_device.h>
@@ -428,6 +429,29 @@ static void edma_tx_fill_desc(struct edm
 
 	/* Set destination information in the descriptor. */
 	EDMA_TXDESC_SERVICE_CODE_SET(txd, PPE_EDMA_SC_BYPASS_ID);
+
+	/* The bridge transmits one copy of a flooded packet when the TX
+	 * forwarding offload is enabled on the port, marked with
+	 * offload_fwd_mark: replicate it to the flood ports of the
+	 * bridge with a bitmap destination.
+	 */
+	if (unlikely(skb->offload_fwd_mark)) {
+		const struct ethhdr *eth = (struct ethhdr *)skb->data;
+		u32 bitmap;
+
+		if (is_broadcast_ether_addr(eth->h_dest))
+			bitmap = READ_ONCE(port_priv->br_flood[EDMA_PORT_FLOOD_BC]);
+		else if (is_multicast_ether_addr(eth->h_dest))
+			bitmap = READ_ONCE(port_priv->br_flood[EDMA_PORT_FLOOD_MC]);
+		else
+			bitmap = READ_ONCE(port_priv->br_flood[EDMA_PORT_FLOOD_UC]);
+
+		if (bitmap) {
+			EDMA_DST_BITMAP_INFO_SET(txd, bitmap);
+			return;
+		}
+	}
+
 	EDMA_DST_INFO_SET(txd, port_id);
 }
 
--- a/drivers/net/ethernet/qualcomm/ppe/edma_tx.h
+++ b/drivers/net/ethernet/qualcomm/ppe/edma_tx.h
@@ -45,6 +45,14 @@
 #define EDMA_DST_INFO_SET(desc, x)	((desc)->word4 |= \
 	(EDMA_DST_PORT_TYPE_SET(EDMA_DST_PORT_TYPE) | EDMA_DST_PORT_ID_SET(x)))
 
+/* A bitmap destination reaches every port of the bitmap with a single
+ * transmitted frame.
+ */
+#define EDMA_DST_PORT_BITMAP_TYPE	3
+#define EDMA_DST_BITMAP_INFO_SET(desc, x)	((desc)->word4 |= \
+	(EDMA_DST_PORT_TYPE_SET(EDMA_DST_PORT_BITMAP_TYPE) | \
+	 EDMA_DST_PORT_ID_SET(x)))
+
 #define EDMA_TXDESC_TSO_ENABLE_MASK		BIT(24)
 #define EDMA_TXDESC_TSO_ENABLE_SET(desc, x)	((desc)->word5 |= \
 				FIELD_PREP(EDMA_TXDESC_TSO_ENABLE_MASK, x))
--- a/drivers/net/ethernet/qualcomm/ppe/ppe_bridge.c
+++ b/drivers/net/ethernet/qualcomm/ppe/ppe_bridge.c
@@ -76,6 +76,8 @@ struct ppe_bridge_vsi {
  * @flags: Offloaded bridge port flags of the port.
  * @mrouter: Port leads to a multicast router and is included in the
  * bitmap of every offloaded multicast group of its bridge.
+ * @forwarding: Port is in the forwarding spanning tree state,
+ * a prerequisite for being a TX flood replication target.
  */
 struct ppe_bridge_port {
 	struct net_device *bridge;
@@ -84,6 +86,7 @@ struct ppe_bridge_port {
 	u16 pvid;
 	unsigned long flags;
 	bool mrouter;
+	bool forwarding;
 };
 
 /* The bridge port flags the offload supports, matching the defaults of
@@ -239,6 +242,8 @@ static int ppe_bridge_vsi_get(struct ppe
 	return -ENOSPC;
 }
 
+static void ppe_bridge_tx_flood_update(struct ppe_bridge *pb, int vsi);
+
 /* Update the member and flood bitmaps of a VSI from its members and
  * their bridge port flags. The CPU port is always a member and a flood
  * target, so that packets without a hit on a hardware FDB entry reach
@@ -272,9 +277,12 @@ static int ppe_bridge_vsi_hw_update(stru
 			bc |= BIT(i);
 	}
 
+	ppe_bridge_tx_flood_update(pb, vsi);
+
 	return ppe_vsi_members_set(pb->ppe_dev, vsi, member, uuc, umc, bc);
 }
 
+
 /* Update the per-port egress tag modes of a VSI. The VSI of a
  * VLAN-unaware bridge leaves packets unmodified on all ports. On a
  * VLAN VSI, member ports egress tagged or untagged as configured,
@@ -526,6 +534,68 @@ static void ppe_bridge_mdb_purge(struct
 	}
 }
 
+/* Push the flood bitmaps of a VLAN-unaware bridge to its member port
+ * net devices for the TX forwarding offload: the bridge transmits one
+ * copy of a flooded packet, and the EDMA replicates it along these
+ * bitmaps. A bitmap destination bypasses the spanning tree state and
+ * the hardware groups, so ports outside the forwarding state are
+ * excluded here, and multicast is the union of the flood members and
+ * the offloaded group members, which can only over-deliver.
+ */
+static void ppe_bridge_tx_flood_update(struct ppe_bridge *pb, int vsi)
+{
+	struct ppe_bridge_vsi *v = &pb->vsis[vsi];
+	u32 fwd = 0, uc = 0, mc = 0, bc = 0;
+	struct ppe_bridge_mdb *mdb;
+	int i, bkt;
+
+	if (v->vid)
+		return;
+
+	for (i = 1; i < pb->ppe_dev->num_ports; i++) {
+		if (!(v->members & BIT(i)))
+			continue;
+
+		if (pb->ports[i].forwarding)
+			fwd |= BIT(i);
+		if (pb->ports[i].flags & BR_FLOOD)
+			uc |= BIT(i);
+		if (pb->ports[i].flags & BR_MCAST_FLOOD)
+			mc |= BIT(i);
+		if (pb->ports[i].flags & BR_BCAST_FLOOD)
+			bc |= BIT(i);
+	}
+
+	hash_for_each(pb->mdb_ht, bkt, mdb, node)
+		if (mdb->vsi == vsi)
+			mc |= mdb->ports;
+
+	uc &= fwd;
+	mc &= fwd;
+	bc &= fwd;
+
+	for (i = 1; i < pb->ppe_dev->num_ports; i++) {
+		struct edma_port_priv *port_priv;
+
+		if (!(v->members & BIT(i)) || !pb->ports[i].dev)
+			continue;
+
+		port_priv = netdev_priv(pb->ports[i].dev);
+		WRITE_ONCE(port_priv->br_flood[EDMA_PORT_FLOOD_UC], uc);
+		WRITE_ONCE(port_priv->br_flood[EDMA_PORT_FLOOD_MC], mc);
+		WRITE_ONCE(port_priv->br_flood[EDMA_PORT_FLOOD_BC], bc);
+	}
+}
+
+static void ppe_bridge_port_tx_flood_clear(struct net_device *dev)
+{
+	struct edma_port_priv *port_priv = netdev_priv(dev);
+	int i;
+
+	for (i = 0; i < EDMA_PORT_FLOOD_MAX; i++)
+		WRITE_ONCE(port_priv->br_flood[i], 0);
+}
+
 /* Release a VSI which lost its last member port: drop its translation
  * rules, park it back to the CPU-only state the PPE core initialized,
  * and flush its FDB entries, including the CPU-directed entries which
@@ -738,6 +808,10 @@ static int ppe_bridge_port_join(struct p
 	pb->ports[port].pvid = 0;
 	pb->ports[port].flags = PPE_BRIDGE_SUPPORTED_FLAGS;
 	pb->ports[port].mrouter = false;
+	/* Excluded from TX flood replication until the bridge reports
+	 * the forwarding state.
+	 */
+	pb->ports[port].forwarding = false;
 
 	if (!vlan_aware) {
 		pb->vsis[vsi].members |= BIT(port);
@@ -772,10 +846,15 @@ static int ppe_bridge_port_join(struct p
 
 	ppe_bridge_port_offload_mark_set(dev, true);
 
+	/* On a VLAN-unaware bridge every replication target receives
+	 * the identical frame, so the bridge may hand over a single
+	 * copy of flooded packets. VLAN-aware bridges keep cloning in
+	 * software, their egress tagging differs per port.
+	 */
 	ret = switchdev_bridge_port_offload(dev, dev, pb,
 					    &pb->switchdev_nb,
 					    &pb->switchdev_blocking_nb,
-					    false, extack);
+					    !vlan_aware, extack);
 	if (ret)
 		goto err_offload;
 
@@ -786,6 +865,7 @@ static int ppe_bridge_port_join(struct p
 
 err_offload:
 	ppe_bridge_port_offload_mark_set(dev, false);
+	ppe_bridge_port_tx_flood_clear(dev);
 	ppe_port_bridge_txmac_set(ppe_dev, port, false);
 err_datapath:
 	if (!vlan_aware)
@@ -821,6 +901,7 @@ static void ppe_bridge_port_leave(struct
 					&pb->switchdev_blocking_nb);
 
 	ppe_bridge_port_offload_mark_set(dev, false);
+	ppe_bridge_port_tx_flood_clear(dev);
 	ppe_port_bridge_txmac_set(ppe_dev, port, false);
 
 	if (!vlan_aware)
@@ -1067,9 +1148,12 @@ static int ppe_bridge_port_mdb_add(struc
 			hash_del(&mdb->node);
 			kfree(mdb);
 		}
+		return ret;
 	}
 
-	return ret;
+	ppe_bridge_tx_flood_update(pb, vsi);
+
+	return 0;
 }
 
 static int ppe_bridge_port_mdb_del(struct ppe_bridge *pb,
@@ -1078,7 +1162,7 @@ static int ppe_bridge_port_mdb_del(struc
 {
 	int port = ppe_bridge_port_id(dev);
 	struct ppe_bridge_mdb *mdb;
-	int vsi;
+	int vsi, ret;
 
 	if (!pb->ports[port].bridge)
 		return -EOPNOTSUPP;
@@ -1092,17 +1176,21 @@ static int ppe_bridge_port_mdb_del(struc
 		return 0;
 
 	mdb->ports &= ~BIT(port);
-	if (mdb->ports)
-		return ppe_bridge_mdb_hw_update(pb, mdb);
+	if (mdb->ports) {
+		ret = ppe_bridge_mdb_hw_update(pb, mdb);
+	} else {
+		/* The last member is gone, the group returns to the
+		 * flood path.
+		 */
+		ppe_bridge_mdb_hw_remove(pb, mdb);
+		hash_del(&mdb->node);
+		kfree(mdb);
+		ret = 0;
+	}
 
-	/* The last member is gone, the group returns to the flood
-	 * path.
-	 */
-	ppe_bridge_mdb_hw_remove(pb, mdb);
-	hash_del(&mdb->node);
-	kfree(mdb);
+	ppe_bridge_tx_flood_update(pb, vsi);
 
-	return 0;
+	return ret;
 }
 
 static int ppe_bridge_stp_state_set(struct ppe_bridge *pb,
@@ -1135,6 +1223,10 @@ static int ppe_bridge_stp_state_set(stru
 	if (ret)
 		return ret;
 
+	pb->ports[port].forwarding = stp_state == PPE_STP_STATE_FORWARDING;
+	if (pb->ports[port].vsi >= 0)
+		ppe_bridge_tx_flood_update(pb, pb->ports[port].vsi);
+
 	if (stp_state != PPE_STP_STATE_FORWARDING)
 		ret = ppe_fdb_port_flush(ppe_dev, port, false);
 
@@ -1236,9 +1328,16 @@ static int ppe_bridge_mc_disabled_set(st
 	int port = ppe_bridge_port_id(dev);
 	struct net_device *br = pb->ports[port].bridge;
 
-	if (disabled)
+	if (disabled) {
+		int i;
+
 		ppe_bridge_mdb_purge(pb, br, -1);
 
+		for (i = 0; i < ARRAY_SIZE(pb->vsis); i++)
+			if (pb->vsis[i].br == br)
+				ppe_bridge_tx_flood_update(pb, i);
+	}
+
 	return 0;
 }
 
