+static int ppe_bridge_obj_add(struct net_device *dev, const void *ctx,
+			      const struct switchdev_obj *obj,
+			      struct netlink_ext_ack *extack)
+{
+	struct edma_port_priv *port_priv = netdev_priv(dev);
+	struct ppe_bridge *pb = port_priv->ppe_port->ppe_dev->bridge;
+
+	/* VLANs of the bridge device itself terminate at the CPU port,
+	 * which is a member of every VSI already.
