+/* Drop the port from every VSI it is a member of, releasing the VSIs
+ * which lose their last member. Used when a port leaves its bridge and
+ * to unwind a failed join.
+ */
+static void ppe_bridge_port_vlans_flush(struct ppe_bridge *pb, int port)
+{
+	struct ppe_bridge_vsi *v;
+	int i;
+
+	if (pb->ports[port].pvid) {
+		ppe_port_default_cvid_set(pb->ppe_dev, port, -1);
+		pb->ports[port].pvid = 0;
+	}
+
+	for (i = 0; i < ARRAY_SIZE(pb->vsis); i++) {
+		v = &pb->vsis[i];
+
+		if (!v->br || !(v->members & BIT(port)))
+			continue;
+
+		v->members &= ~BIT(port);
+		v->untagged &= ~BIT(port);
+		v->pvids &= ~BIT(port);
+
+		if (!v->members) {
+			ppe_bridge_vsi_release(pb, i);
+			continue;
+		}
+
+		ppe_bridge_vsi_xlt_update(pb, i);
+		ppe_bridge_vsi_hw_update(pb, i);
+		ppe_bridge_vsi_eg_update(pb, i);
+	}
+}
