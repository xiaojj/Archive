+/* Release a VSI which lost its last member port: drop its translation
+ * rules, park it back to the CPU-only state the PPE core initialized,
+ * and flush its FDB entries, including the CPU-directed entries which
+ * are not tied to any PPE port.
+ */
+static void ppe_bridge_vsi_release(struct ppe_bridge *pb, int vsi)
+{
+	struct ppe_bridge_vsi *v = &pb->vsis[vsi];
+
+	v->members = 0;
+	v->untagged = 0;
+	v->pvids = 0;
+
+	ppe_bridge_vsi_xlt_update(pb, vsi);
+	ppe_bridge_vsi_hw_update(pb, vsi);
+
+	v->br = NULL;
+	v->vid = 0;
+
+	ppe_bridge_vsi_eg_update(pb, vsi);
+	ppe_fdb_vsi_flush(pb->ppe_dev, vsi);
+	ppe_bridge_fdb_shadow_purge(pb, -1, vsi);
+}
