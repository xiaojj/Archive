+	case SWITCHDEV_OBJ_ID_PORT_VLAN:
+		return ppe_bridge_port_vlan_add(pb, dev,
+						SWITCHDEV_OBJ_PORT_VLAN(obj),
+						extack);
+	default:
+		return -EOPNOTSUPP;
+	}
