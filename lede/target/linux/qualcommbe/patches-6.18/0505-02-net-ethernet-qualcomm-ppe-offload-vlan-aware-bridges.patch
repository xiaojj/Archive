+	return ppe_vsi_members_set(pb->ppe_dev, vsi, member, uuc, umc, bc);
 }
 
 /* Update the per-port egress tag modes of a VSI. The VSI of a
- * VLAN-unaware bridge leaves packets unmodified on all ports: the VSI
- * tag modes apply out of hardware reset, and the default mode would
- * strip VLAN tags on egress.
+ * VLAN-unaware bridge leaves packets unmodified on all ports. On a
+ * VLAN VSI, member ports egress tagged or untagged as configured,
+ * non-member ports (which never see VSI-forwarded traffic) are left
+ * unmodified, and the CPU port egresses tagged, so that the software
+ * ports of the bridge see the VLAN of flooded packets.
  */
 static int ppe_bridge_vsi_eg_update(struct ppe_bridge *pb, int vsi)
 {
+	struct ppe_bridge_vsi *v = &pb->vsis[vsi];
 	u32 modes = 0;
-	int i;
+	int i, mode;
 
-	for (i = 0; i < pb->ppe_dev->num_ports; i++)
-		modes |= PPE_EG_VLAN_MODE_UNMODIFIED << (i * 2);
+	for (i = 0; i < pb->ppe_dev->num_ports; i++) {
+		if (!v->vid)
+			mode = PPE_EG_VLAN_MODE_UNMODIFIED;
+		else if (i == 0)
+			mode = PPE_EG_VLAN_MODE_TAGGED;
+		else if (!(v->members & BIT(i)))
+			mode = PPE_EG_VLAN_MODE_UNMODIFIED;
+		else if (v->untagged & BIT(i))
+			mode = PPE_EG_VLAN_MODE_UNTAGGED;
+		else
+			mode = PPE_EG_VLAN_MODE_TAGGED;
+
+		modes |= mode << (i * 2);
+	}
 
 	return ppe_vsi_eg_mode_set(pb->ppe_dev, vsi, modes);
 }
 
+/* Keep the two ingress translation rules of a VLAN VSI in sync with
+ * its state: one rule assigning tagged packets of the VLAN on the
+ * member ports, one rule assigning untagged and priority-tagged
+ * packets on the ports with this VLAN as PVID. Rules are allocated
+ * and released as the port bitmaps become non-empty and empty.
+ */
+static int ppe_bridge_vsi_xlt_update(struct ppe_bridge *pb, int vsi)
+{
+	struct ppe_bridge_vsi *v = &pb->vsis[vsi];
+	struct {
+		unsigned int bitmap;
+		int vid;
+		int *index;
+	} rules[2] = {
+		{ v->members, v->vid, &v->xlt_tagged },
+		{ v->pvids, -1, &v->xlt_pvid },
+	};
+	int i, idx, ret;
+
+	/* The VSI of a VLAN-unaware bridge binds its ports directly
+	 * and has no translation rules.
+	 */
+	if (!v->vid)
+		return 0;
+
+	for (i = 0; i < ARRAY_SIZE(rules); i++) {
+		idx = *rules[i].index;
+
+		if (!rules[i].bitmap) {
+			if (idx < 0)
+				continue;
+
+			ret = ppe_ing_xlt_rule_clear(pb->ppe_dev, idx);
+			if (ret)
+				return ret;
+
+			clear_bit(idx, pb->xlt_used);
+			*rules[i].index = -1;
+			continue;
+		}
+
+		if (idx < 0) {
+			idx = find_first_zero_bit(pb->xlt_used,
+						  PPE_XLT_RULE_TBL_ENTRIES);
+			if (idx >= PPE_XLT_RULE_TBL_ENTRIES)
+				return -ENOSPC;
+		}
+
+		ret = ppe_ing_xlt_rule_set(pb->ppe_dev, idx, rules[i].bitmap,
+					   rules[i].vid, vsi);
+		if (ret)
+			return ret;
+
+		set_bit(idx, pb->xlt_used);
+		*rules[i].index = idx;
+	}
+
+	return 0;
+}
