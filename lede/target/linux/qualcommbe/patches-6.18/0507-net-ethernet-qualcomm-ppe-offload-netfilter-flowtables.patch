--- /dev/null
+++ b/drivers/net/ethernet/qualcomm/ppe/ppe_flowtable.c
@@ -0,0 +1,865 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Copyright (c) 2026 Kenneth Kasilag <kenneth@kasilag.me>
+ */
+
+/* Offload of netfilter flowtables to the PPE L3 flow engine.
+ *
+ * The PPE port net devices accept flow block bindings through
+ * ndo_setup_tc(TC_SETUP_FT). Offloaded rules translate to a next hop
+ * entry (egress port, MAC rewrites, VLAN, NAT addresses) and a flow
+ * entry (the 5-tuple and the translated L4 port). The router MAC
+ * table is maintained from the source MAC rewrite of the rules: the
+ * egress source MAC of one direction is the MAC the reverse direction
+ * ingresses on. Flows the hardware cannot express fall back to the
+ * software flowtable path.
+ */
+
+#include <linux/etherdevice.h>
+#include <linux/hashtable.h>
+#include <linux/if_vlan.h>
+#include <linux/ip.h>
+#include <linux/netdevice.h>
+#include <linux/rhashtable.h>
+#include <net/flow_offload.h>
+
+#include "edma_port.h"
+#include "ppe.h"
+#include "ppe_config.h"
+#include "ppe_flow.h"
+#include "ppe_flowtable.h"
+#include "ppe_regs.h"
+
+/**
+ * struct ppe_ft_ref - Common head of a refcounted hardware-entry table.
+ * @refcnt: Number of flows using the entry, 0 when free.
+ *
+ * A refcounted table backs hardware entries shared by many flows: a
+ * flow takes a reference on the entry matching its key, a free entry
+ * is programmed on first use, and the hardware entry is released when
+ * the last reference drops. The scan and the reference bookkeeping
+ * live in ppe_ft_ref_get() and ppe_ft_ref_put(); the key match and
+ * the hardware programming stay with each table. Every entry type
+ * embeds this as its first member.
+ */
+struct ppe_ft_ref {
+	unsigned int refcnt;
+};
+
+/**
+ * struct ppe_ft_my_mac - A refcounted router MAC slot.
+ * @ref: Reference count of the slot.
+ * @addr: MAC address of the slot.
+ */
+struct ppe_ft_my_mac {
+	struct ppe_ft_ref ref;
+	u8 addr[ETH_ALEN];
+};
+
+static_assert(offsetof(struct ppe_ft_my_mac, ref) == 0);
+
+/**
+ * struct ppe_ft_pub_ip - A refcounted public IP slot.
+ * @ref: Reference count of the slot.
+ * @ip: IPv4 address of the slot.
+ */
+struct ppe_ft_pub_ip {
+	struct ppe_ft_ref ref;
+	__be32 ip;
+};
+
+static_assert(offsetof(struct ppe_ft_pub_ip, ref) == 0);
+
+/**
+ * struct ppe_ft_flow - An offloaded flow.
+ * @node: Hash table node, keyed by the flow cookie.
+ * @cookie: Flow cookie of the rule.
+ * @index: Hardware flow table index.
+ * @entry: The flow, kept for the delete command.
+ * @nexthop: Next hop index of the flow.
+ * @my_mac: Router MAC slot held by the flow, negative when none.
+ * @pub_ip: Public IP slot held by the flow, negative when none.
+ * @packets: Hit packet count at the last stats read.
+ * @bytes: Hit byte count at the last stats read.
+ */
+struct ppe_ft_flow {
+	struct rhash_head node;
+	unsigned long cookie;
+	int index;
+	struct ppe_flow_entry entry;
+	u16 nexthop;
+	int my_mac;
+	int pub_ip;
+	u32 packets;
+	u64 bytes;
+};
+
+#define PPE_FT_HOST_HASH_BITS	8
+
+/* Refcount of the flows sharing a destination host entry, so the
+ * hardware host entry (added by the combined flow-and-host command)
+ * is removed only with the last of them.
+ */
+struct ppe_ft_host {
+	struct hlist_node node;
+	union {
+		__be32 ip4;
+		struct in6_addr ip6;
+	} dip;
+	bool is_ipv6;
+	unsigned int refcnt;
+};
+
+/**
+ * struct ppe_flowtable - Flowtable offload state of the PPE.
+ * @ppe_dev: Back pointer to the PPE device.
+ * @lock: Serializes rule installation, removal and the allocators.
+ * @flows: Offloaded flows, keyed by flow cookie.
+ * @nexthop_used: Allocation bitmap of the next hop entries.
+ * @my_macs: Refcounted router MAC slots.
+ * @pub_ips: Refcounted public IP slots.
+ * @block_cb_list: Flow block callbacks bound to the PPE ports.
+ * @hosts: Refcount of the flows sharing a destination host entry.
+ */
+struct ppe_flowtable {
+	struct ppe_device *ppe_dev;
+	struct mutex lock;
+	struct rhashtable flows;
+	DECLARE_HASHTABLE(hosts, PPE_FT_HOST_HASH_BITS);
+	DECLARE_BITMAP(nexthop_used, PPE_NEXTHOP_TBL_ENTRIES);
+	struct ppe_ft_my_mac my_macs[PPE_MY_MAC_TBL_ENTRIES];
+	struct ppe_ft_pub_ip pub_ips[PPE_PUB_IP_TBL_ENTRIES];
+	struct list_head block_cb_list;
+};
+
+static const struct rhashtable_params ppe_ft_params = {
+	.head_offset = offsetof(struct ppe_ft_flow, node),
+	.key_offset = offsetof(struct ppe_ft_flow, cookie),
+	.key_len = sizeof(unsigned long),
+	.automatic_shrinking = true,
+};
+
+/* The mangle words of an offloaded rule, collected before translation.
+ * The Ethernet buffer overlays the destination and source addresses as
+ * they appear in the header.
+ */
+struct ppe_ft_data {
+	struct {
+		u8 dst[ETH_ALEN];
+		u8 src[ETH_ALEN];
+	} eth;
+	__be32 sip;
+	__be32 dip;
+	__be16 sport;
+	__be16 dport;
+};
+
+static void ppe_ft_mangle_eth(const struct flow_action_entry *act, void *eth)
+{
+	const void *src = &act->mangle.val;
+	void *dest = eth + act->mangle.offset;
+
+	if (act->mangle.offset > 8)
+		return;
+
+	if (act->mangle.mask == 0xffff) {
+		src += 2;
+		dest += 2;
+	}
+
+	memcpy(dest, src, act->mangle.mask == 0xffff ? 2 : 4);
+}
+
+static void ppe_ft_mangle_ipv4(const struct flow_action_entry *act,
+			       struct ppe_ft_data *data)
+{
+	__be32 val = (__force __be32)act->mangle.val;
+
+	switch (act->mangle.offset) {
+	case offsetof(struct iphdr, saddr):
+		data->sip = val;
+		break;
+	case offsetof(struct iphdr, daddr):
+		data->dip = val;
+		break;
+	}
+}
+
+static void ppe_ft_mangle_ports(const struct flow_action_entry *act,
+				struct ppe_ft_data *data)
+{
+	u32 val = ntohl(act->mangle.val);
+
+	switch (act->mangle.offset) {
+	case 0:
+		if (act->mangle.mask == ~htonl(0xffff))
+			data->dport = cpu_to_be16(val);
+		else
+			data->sport = cpu_to_be16(val >> 16);
+		break;
+	case 2:
+		data->dport = cpu_to_be16(val);
+		break;
+	}
+}
+
+/* Return entry @index of a refcounted table whose entries are @esize
+ * bytes each and embed struct ppe_ft_ref as their first member.
+ */
+static void *ppe_ft_ref_entry(void *table, size_t esize, int index)
+{
+	return (char *)table + index * esize;
+}
+
+/* Take a reference on the table entry matching the key, returning its
+ * index. A free entry's index is returned with *is_new set instead
+ * when no entry matches: the caller programs the hardware and commits
+ * the entry with its first reference. -ENOSPC when the table is full.
+ * Must be called with the flowtable lock held.
+ */
+static int ppe_ft_ref_get(void *table, size_t esize, int num,
+			  bool (*match)(const void *entry, const void *key),
+			  const void *key, bool *is_new)
+{
+	int i, free = -1;
+
+	*is_new = false;
+
+	for (i = 0; i < num; i++) {
+		struct ppe_ft_ref *ref = ppe_ft_ref_entry(table, esize, i);
+
+		if (!ref->refcnt) {
+			if (free < 0)
+				free = i;
+			continue;
+		}
+
+		if (match(ref, key)) {
+			ref->refcnt++;
+			return i;
+		}
+	}
+
+	if (free < 0)
+		return -ENOSPC;
+
+	*is_new = true;
+	return free;
+}
+
+/* Drop a reference; true when the last one went and the caller must
+ * release the hardware entry. Must be called with the flowtable lock
+ * held.
+ */
+static bool ppe_ft_ref_put(void *table, size_t esize, int index)
+{
+	struct ppe_ft_ref *ref;
+
+	if (index < 0)
+		return false;
+
+	ref = ppe_ft_ref_entry(table, esize, index);
+	if (!ref->refcnt || --ref->refcnt)
+		return false;
+
+	return true;
+}
+
+static bool ppe_ft_my_mac_match(const void *entry, const void *key)
+{
+	const struct ppe_ft_my_mac *slot = entry;
+
+	return ether_addr_equal(slot->addr, key);
+}
+
+/* Get a refcounted router MAC slot for the address, programming the
+ * hardware entry on first use. Must be called with the flowtable lock
+ * held.
+ */
+static int ppe_ft_my_mac_get(struct ppe_flowtable *ft, const u8 *addr)
+{
+	bool is_new;
+	int i, ret;
+
+	i = ppe_ft_ref_get(ft->my_macs, sizeof(*ft->my_macs),
+			   PPE_MY_MAC_TBL_ENTRIES, ppe_ft_my_mac_match,
+			   addr, &is_new);
+	if (i < 0 || !is_new)
+		return i;
+
+	ret = ppe_my_mac_set(ft->ppe_dev, i, addr, true);
+	if (ret)
+		return ret;
+
+	ether_addr_copy(ft->my_macs[i].addr, addr);
+	ft->my_macs[i].ref.refcnt = 1;
+
+	return i;
+}
+
+static void ppe_ft_my_mac_put(struct ppe_flowtable *ft, int index)
+{
+	if (!ppe_ft_ref_put(ft->my_macs, sizeof(*ft->my_macs), index))
+		return;
+
+	ppe_my_mac_set(ft->ppe_dev, index, ft->my_macs[index].addr, false);
+}
+
+static bool ppe_ft_pub_ip_match(const void *entry, const void *key)
+{
+	const struct ppe_ft_pub_ip *slot = entry;
+
+	return slot->ip == *(const __be32 *)key;
+}
+
+/* Get a refcounted public IP slot for the address, programming the
+ * hardware entry on first use. Must be called with the flowtable lock
+ * held.
+ */
+static int ppe_ft_pub_ip_get(struct ppe_flowtable *ft, __be32 ip)
+{
+	bool is_new;
+	int i, ret;
+
+	i = ppe_ft_ref_get(ft->pub_ips, sizeof(*ft->pub_ips),
+			   PPE_PUB_IP_TBL_ENTRIES, ppe_ft_pub_ip_match,
+			   &ip, &is_new);
+	if (i < 0 || !is_new)
+		return i;
+
+	ret = ppe_pub_ip_set(ft->ppe_dev, i, ip);
+	if (ret)
+		return ret;
+
+	ft->pub_ips[i].ip = ip;
+	ft->pub_ips[i].ref.refcnt = 1;
+
+	return i;
+}
+
+/* Only router MAC slots have a validity bit to clear: a stale public
+ * IP is unreachable once no next hop references it.
+ */
+static void ppe_ft_pub_ip_put(struct ppe_flowtable *ft, int index)
+{
+	ppe_ft_ref_put(ft->pub_ips, sizeof(*ft->pub_ips), index);
+}
+
+/* Hash key of a flow's destination IP for the host refcount table. */
+static u32 ppe_ft_host_key(const struct ppe_flow_entry *flow)
+{
+	if (flow->is_ipv6)
+		return flow->dip.ip6.s6_addr32[0] ^ flow->dip.ip6.s6_addr32[1] ^
+		       flow->dip.ip6.s6_addr32[2] ^ flow->dip.ip6.s6_addr32[3];
+
+	return (__force u32)flow->dip.ip4;
+}
+
+static bool ppe_ft_host_match(const struct ppe_ft_host *host,
+			      const struct ppe_flow_entry *flow)
+{
+	if (host->is_ipv6 != flow->is_ipv6)
+		return false;
+
+	if (flow->is_ipv6)
+		return !memcmp(&host->dip.ip6, &flow->dip.ip6,
+			       sizeof(host->dip.ip6));
+
+	return host->dip.ip4 == flow->dip.ip4;
+}
+
+/* Take a reference on the host entry of a flow's destination, so flows
+ * sharing a destination share one hardware host entry. Must be called
+ * with the flowtable lock held.
+ */
+static int ppe_ft_host_get(struct ppe_flowtable *ft,
+			   const struct ppe_flow_entry *flow)
+{
+	u32 key = ppe_ft_host_key(flow);
+	struct ppe_ft_host *host;
+
+	hash_for_each_possible(ft->hosts, host, node, key)
+		if (ppe_ft_host_match(host, flow)) {
+			host->refcnt++;
+			return 0;
+		}
+
+	host = kzalloc(sizeof(*host), GFP_KERNEL);
+	if (!host)
+		return -ENOMEM;
+
+	if (flow->is_ipv6)
+		host->dip.ip6 = flow->dip.ip6;
+	else
+		host->dip.ip4 = flow->dip.ip4;
+	host->is_ipv6 = flow->is_ipv6;
+	host->refcnt = 1;
+	hash_add(ft->hosts, &host->node, key);
+
+	return 0;
+}
+
+/* Drop a reference on the host entry of a flow's destination. Returns
+ * true when it was the last, so the caller removes the hardware host
+ * entry together with the flow. Must be called with the flowtable lock
+ * held.
+ */
+static bool ppe_ft_host_put(struct ppe_flowtable *ft,
+			    const struct ppe_flow_entry *flow)
+{
+	u32 key = ppe_ft_host_key(flow);
+	struct ppe_ft_host *host;
+
+	hash_for_each_possible(ft->hosts, host, node, key)
+		if (ppe_ft_host_match(host, flow)) {
+			if (--host->refcnt)
+				return false;
+			hash_del(&host->node);
+			kfree(host);
+			return true;
+		}
+
+	return true;
+}
+
+/* Delete the hardware entry of a flow. After a failed delete the entry
+ * keeps forwarding, so the caller must leak the next hop and the table
+ * slots of the flow rather than have them reused under the live entry.
+ */
+static bool ppe_ft_flow_hw_del(struct ppe_flowtable *ft,
+			       struct ppe_ft_flow *flow, bool with_host)
+{
+	int ret = ppe_flow_entry_del(ft->ppe_dev, &flow->entry, with_host);
+
+	if (!ret || ret == -ENOENT)
+		return true;
+
+	WARN_ONCE(1, "leaking the resources of an undeletable PPE flow\n");
+	return false;
+}
+
+static int ppe_ft_flow_replace(struct ppe_flowtable *ft,
+			       struct flow_cls_offload *f)
+{
+	struct flow_rule *rule = flow_cls_offload_flow_rule(f);
+	struct edma_port_priv *port_priv;
+	struct flow_action_entry *act;
+	struct net_device *odev = NULL;
+	struct ppe_flow_nexthop nh = {};
+	struct ppe_ft_data data = {};
+	struct ppe_ft_flow *flow;
+	int i, nexthop, ret;
+
+	if (!flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_BASIC) ||
+	    !flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_IPV4_ADDRS) ||
+	    !flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_PORTS))
+		return -EOPNOTSUPP;
+
+	/* VLAN-tagged ingress is not translated to a flow key yet. */
+	if (flow_rule_match_key(rule, FLOW_DISSECTOR_KEY_VLAN))
+		return -EOPNOTSUPP;
+
+	flow = kzalloc(sizeof(*flow), GFP_KERNEL);
+	if (!flow)
+		return -ENOMEM;
+
+	flow->cookie = f->cookie;
+	flow->my_mac = -1;
+	flow->pub_ip = -1;
+	nh.vid = -1;
+
+	{
+		struct flow_match_basic match;
+
+		flow_rule_match_basic(rule, &match);
+		if (match.key->n_proto != htons(ETH_P_IP)) {
+			ret = -EOPNOTSUPP;
+			goto err_free;
+		}
+
+		switch (match.key->ip_proto) {
+		case IPPROTO_TCP:
+			flow->entry.proto = PPE_FLOW_PROTOCOL_TCP;
+			break;
+		case IPPROTO_UDP:
+			flow->entry.proto = PPE_FLOW_PROTOCOL_UDP;
+			break;
+		default:
+			ret = -EOPNOTSUPP;
+			goto err_free;
+		}
+	}
+
+	{
+		struct flow_match_ipv4_addrs match;
+
+		flow_rule_match_ipv4_addrs(rule, &match);
+		flow->entry.sip = match.key->src;
+		flow->entry.dip = match.key->dst;
+	}
+
+	{
+		struct flow_match_ports match;
+
+		flow_rule_match_ports(rule, &match);
+		flow->entry.sport = match.key->src;
+		flow->entry.dport = match.key->dst;
+	}
+
+	data.sip = flow->entry.sip;
+	data.dip = flow->entry.dip;
+	data.sport = flow->entry.sport;
+	data.dport = flow->entry.dport;
+
+	flow_action_for_each(i, act, &rule->action) {
+		switch (act->id) {
+		case FLOW_ACTION_REDIRECT:
+			odev = act->dev;
+			break;
+		case FLOW_ACTION_MANGLE:
+			switch (act->mangle.htype) {
+			case FLOW_ACT_MANGLE_HDR_TYPE_ETH:
+				ppe_ft_mangle_eth(act, &data.eth);
+				break;
+			case FLOW_ACT_MANGLE_HDR_TYPE_IP4:
+				ppe_ft_mangle_ipv4(act, &data);
+				break;
+			case FLOW_ACT_MANGLE_HDR_TYPE_TCP:
+			case FLOW_ACT_MANGLE_HDR_TYPE_UDP:
+				ppe_ft_mangle_ports(act, &data);
+				break;
+			default:
+				ret = -EOPNOTSUPP;
+				goto err_free;
+			}
+			break;
+		case FLOW_ACTION_VLAN_PUSH:
+			if (act->vlan.proto != htons(ETH_P_8021Q)) {
+				ret = -EOPNOTSUPP;
+				goto err_free;
+			}
+			nh.vid = act->vlan.vid;
+			break;
+		case FLOW_ACTION_CSUM:
+			break;
+		default:
+			ret = -EOPNOTSUPP;
+			goto err_free;
+		}
+	}
+
+	if (!odev || !edma_port_dev_check(odev) ||
+	    is_zero_ether_addr(data.eth.dst)) {
+		ret = -EOPNOTSUPP;
+		goto err_free;
+	}
+
+	port_priv = netdev_priv(odev);
+	nh.port = port_priv->ppe_port->port_id;
+	nh.l3_if = nh.port;
+	ether_addr_copy(nh.mac, data.eth.dst);
+
+	/* The hardware rewrites one direction per flow: the translated
+	 * source of SNAT comes from the public IP table, the translated
+	 * destination of DNAT from the next hop, and the translated L4
+	 * port from the flow entry itself.
+	 */
+	mutex_lock(&ft->lock);
+
+	if (data.sip != flow->entry.sip && data.dip != flow->entry.dip) {
+		ret = -EOPNOTSUPP;
+		goto err_unlock;
+	} else if (data.sip != flow->entry.sip ||
+		   data.sport != flow->entry.sport) {
+		flow->entry.fwd_type = PPE_FLOW_FWD_TYPE_SNAT;
+		flow->entry.nat_port = data.sport;
+
+		flow->pub_ip = ppe_ft_pub_ip_get(ft, data.sip);
+		if (flow->pub_ip < 0) {
+			ret = flow->pub_ip;
+			goto err_unlock;
+		}
+		nh.pub_ip_index = flow->pub_ip;
+	} else if (data.dip != flow->entry.dip ||
+		   data.dport != flow->entry.dport) {
+		flow->entry.fwd_type = PPE_FLOW_FWD_TYPE_DNAT;
+		flow->entry.nat_port = data.dport;
+		nh.dnat_ip = data.dip;
+	} else {
+		flow->entry.fwd_type = PPE_FLOW_FWD_TYPE_ROUTE;
+	}
+
+	/* The source MAC of this direction is the router MAC the
+	 * reverse direction ingresses on; the egress L3 interface of
+	 * the port provides the rewrite.
+	 */
+	if (!is_zero_ether_addr(data.eth.src)) {
+		flow->my_mac = ppe_ft_my_mac_get(ft, data.eth.src);
+		if (flow->my_mac < 0) {
+			ret = flow->my_mac;
+			goto err_pub_ip;
+		}
+
+		ret = ppe_l3_if_set(ft->ppe_dev, nh.l3_if, data.eth.src,
+				    odev->mtu);
+		if (ret)
+			goto err_my_mac;
+
+		ret = ppe_port_l3_if_set(ft->ppe_dev, nh.port, nh.l3_if);
+		if (ret)
+			goto err_my_mac;
+	}
+
+	nexthop = find_first_zero_bit(ft->nexthop_used,
+				      PPE_NEXTHOP_TBL_ENTRIES);
+	if (nexthop >= PPE_NEXTHOP_TBL_ENTRIES) {
+		ret = -ENOSPC;
+		goto err_my_mac;
+	}
+
+	ret = ppe_nexthop_set(ft->ppe_dev, nexthop, &nh);
+	if (ret)
+		goto err_my_mac;
+
+	flow->nexthop = nexthop;
+	flow->entry.nexthop = nexthop;
+
+	ret = ppe_ft_host_get(ft, &flow->entry);
+	if (ret)
+		goto err_my_mac;
+
+	ret = ppe_flow_entry_add(ft->ppe_dev, &flow->entry);
+	if (ret < 0)
+		goto err_host;
+	flow->index = ret;
+
+	ret = rhashtable_insert_fast(&ft->flows, &flow->node, ppe_ft_params);
+	if (ret)
+		goto err_hw_flow;
+
+	set_bit(nexthop, ft->nexthop_used);
+	mutex_unlock(&ft->lock);
+
+	return 0;
+
+err_hw_flow:
+	if (!ppe_ft_flow_hw_del(ft, flow, ppe_ft_host_put(ft, &flow->entry))) {
+		/* The hardware flow could not be removed and keeps forwarding
+		 * through its next hop; reserve that next-hop index so it is not
+		 * reused underneath the leaked flow.
+		 */
+		set_bit(flow->nexthop, ft->nexthop_used);
+		goto err_unlock;
+	}
+	goto err_my_mac;
+err_host:
+	ppe_ft_host_put(ft, &flow->entry);
+err_my_mac:
+	ppe_ft_my_mac_put(ft, flow->my_mac);
+err_pub_ip:
+	ppe_ft_pub_ip_put(ft, flow->pub_ip);
+err_unlock:
+	mutex_unlock(&ft->lock);
+err_free:
+	kfree(flow);
+
+	return ret;
+}
+
+static int ppe_ft_flow_destroy(struct ppe_flowtable *ft,
+			       struct flow_cls_offload *f)
+{
+	struct ppe_ft_flow *flow;
+
+	mutex_lock(&ft->lock);
+
+	flow = rhashtable_lookup_fast(&ft->flows, &f->cookie, ppe_ft_params);
+	if (!flow) {
+		mutex_unlock(&ft->lock);
+		return -ENOENT;
+	}
+
+	rhashtable_remove_fast(&ft->flows, &flow->node, ppe_ft_params);
+
+	if (ppe_ft_flow_hw_del(ft, flow, ppe_ft_host_put(ft, &flow->entry))) {
+		clear_bit(flow->nexthop, ft->nexthop_used);
+		ppe_ft_my_mac_put(ft, flow->my_mac);
+		ppe_ft_pub_ip_put(ft, flow->pub_ip);
+	}
+
+	mutex_unlock(&ft->lock);
+	kfree(flow);
+
+	return 0;
+}
+
+static int ppe_ft_flow_stats(struct ppe_flowtable *ft,
+			     struct flow_cls_offload *f)
+{
+	struct ppe_ft_flow *flow;
+	u32 packets;
+	u64 bytes;
+	int ret;
+
+	mutex_lock(&ft->lock);
+
+	flow = rhashtable_lookup_fast(&ft->flows, &f->cookie, ppe_ft_params);
+	if (!flow) {
+		mutex_unlock(&ft->lock);
+		return -ENOENT;
+	}
+
+	ret = ppe_flow_stats_get(ft->ppe_dev, flow->index, &packets, &bytes);
+	if (!ret && (packets != flow->packets || bytes != flow->bytes)) {
+		/* The hardware byte counter is 40 bits wide and wraps. */
+		flow_stats_update(&f->stats,
+				  (bytes - flow->bytes) & GENMASK_ULL(39, 0),
+				  packets - flow->packets, 0, jiffies,
+				  FLOW_ACTION_HW_STATS_DELAYED);
+		flow->packets = packets;
+		flow->bytes = bytes;
+	}
+
+	mutex_unlock(&ft->lock);
+
+	return ret;
+}
+
+static int ppe_ft_block_cb(enum tc_setup_type type, void *type_data,
+			   void *cb_priv)
+{
+	struct ppe_flowtable *ft = cb_priv;
+	struct flow_cls_offload *f = type_data;
+
+	if (type != TC_SETUP_CLSFLOWER)
+		return -EOPNOTSUPP;
+
+	switch (f->command) {
+	case FLOW_CLS_REPLACE:
+		return ppe_ft_flow_replace(ft, f);
+	case FLOW_CLS_DESTROY:
+		return ppe_ft_flow_destroy(ft, f);
+	case FLOW_CLS_STATS:
+		return ppe_ft_flow_stats(ft, f);
+	default:
+		return -EOPNOTSUPP;
+	}
+}
+
+/**
+ * ppe_flowtable_setup_tc - Bind a flow block to a PPE port
+ * @dev: PPE port net device
+ * @type_data: Flow block offload request
+ *
+ * Return: 0 on success, negative error code on failure.
+ */
+int ppe_flowtable_setup_tc(struct net_device *dev, void *type_data)
+{
+	struct edma_port_priv *port_priv = netdev_priv(dev);
+	struct ppe_flowtable *ft = port_priv->ppe_port->ppe_dev->flowtable;
+	struct flow_block_offload *f = type_data;
+	struct flow_block_cb *block_cb;
+
+	if (!ft)
+		return -EOPNOTSUPP;
+
+	if (f->binder_type != FLOW_BLOCK_BINDER_TYPE_CLSACT_INGRESS)
+		return -EOPNOTSUPP;
+
+	f->driver_block_list = &ft->block_cb_list;
+
+	switch (f->command) {
+	case FLOW_BLOCK_BIND:
+		block_cb = flow_block_cb_lookup(f->block, ppe_ft_block_cb,
+						ft);
+		if (block_cb) {
+			flow_block_cb_incref(block_cb);
+			return 0;
+		}
+
+		block_cb = flow_block_cb_alloc(ppe_ft_block_cb, ft, ft, NULL);
+		if (IS_ERR(block_cb))
+			return PTR_ERR(block_cb);
+
+		flow_block_cb_incref(block_cb);
+		flow_block_cb_add(block_cb, f);
+		list_add_tail(&block_cb->driver_list, &ft->block_cb_list);
+		return 0;
+	case FLOW_BLOCK_UNBIND:
+		block_cb = flow_block_cb_lookup(f->block, ppe_ft_block_cb, ft);
+		if (!block_cb)
+			return -ENOENT;
+
+		if (!flow_block_cb_decref(block_cb)) {
+			flow_block_cb_remove(block_cb, f);
+			list_del(&block_cb->driver_list);
+		}
+		return 0;
+	default:
+		return -EOPNOTSUPP;
+	}
+}
+
+/**
+ * ppe_flowtable_setup - Set up the flowtable offload state
+ * @ppe_dev: PPE device
+ *
+ * Return: 0 on success, negative error code on failure.
+ */
+int ppe_flowtable_setup(struct ppe_device *ppe_dev)
+{
+	struct ppe_flowtable *ft;
+	int ret;
+
+	ft = kzalloc(sizeof(*ft), GFP_KERNEL);
+	if (!ft)
+		return -ENOMEM;
+
+	ft->ppe_dev = ppe_dev;
+	mutex_init(&ft->lock);
+	INIT_LIST_HEAD(&ft->block_cb_list);
+
+	ret = rhashtable_init(&ft->flows, &ppe_ft_params);
+	if (ret) {
+		kfree(ft);
+		return ret;
+	}
+
+	hash_init(ft->hosts);
+	ppe_dev->flowtable = ft;
+
+	return 0;
+}
+
+static void ppe_ft_flow_free(void *ptr, void *arg)
+{
+	kfree(ptr);
+}
+
+/**
+ * ppe_flowtable_destroy - Tear down the flowtable offload state
+ * @ppe_dev: PPE device
+ *
+ * The flow blocks are unbound before the net devices go away, this
+ * only releases the bookkeeping.
+ */
+void ppe_flowtable_destroy(struct ppe_device *ppe_dev)
+{
+	struct ppe_flowtable *ft = ppe_dev->flowtable;
+	struct ppe_ft_host *host;
+	struct hlist_node *tmp;
+	int i;
+
+	if (!ft)
+		return;
+
+	ppe_dev->flowtable = NULL;
+	rhashtable_free_and_destroy(&ft->flows, ppe_ft_flow_free, NULL);
+
+	hash_for_each_safe(ft->hosts, i, tmp, host, node) {
+		hash_del(&host->node);
+		kfree(host);
+	}
+
+	kfree(ft);
+}
