From: Kenneth Kasilag <kenneth@kasilag.me>
Date: Sun, 05 Jul 2026 00:00:00 +0000
Subject: [PATCH] net: ethernet: qualcomm: ppe: deliver virtual port flows on receive

A flow forwarded to a virtual port arrives on an EDMA receive ring with
the virtual port in the descriptor's destination info. Recognize it,
resolve the bound net device and transmit the already-rewritten frame
out of it instead of receiving it up the stack. The frame is complete
and NAT'd, so it only needs handing to the device's transmit path.

Linear packets are handled, which is what the offloaded flows produce.
Gated on the SoC variant.

Signed-off-by: Kenneth Kasilag <kenneth@kasilag.me>
---
--- a/drivers/net/ethernet/qualcomm/ppe/edma_rx.c
+++ b/drivers/net/ethernet/qualcomm/ppe/edma_rx.c
@@ -20,6 +20,13 @@
 #include "edma_port.h"
 #include "ppe.h"
 #include "ppe_regs.h"
+#include "ppe_vp.h"
+
+/* Both the single- and multi-buffer receive paths deliver virtual-port
+ * frames; forward-declared as the multi-buffer path precedes the body.
+ */
+static bool edma_rx_deliver_vp(struct edma_rxdesc_pri *rxdesc_pri,
+			       struct sk_buff *skb);
 
 static int edma_rx_alloc_buffer_list(struct edma_rxfill_ring *rxfill_ring, int alloc_count)
 {
@@ -216,6 +223,16 @@ static void edma_rx_process_last_segment
 	pr_debug("edma_context:%pK skb:%pK Jumbo pkt_length:%u\n",
 		 edma_ctx, skb_head, skb_head->len);
 
+	/* A packet forwarded to a virtual port is transmitted out its
+	 * bound device instead of being received up the stack.
+	 */
+	if (edma_rx_deliver_vp(rxdesc_ring->pdesc_head, skb_head)) {
+		rxdesc_ring->head = NULL;
+		rxdesc_ring->last = NULL;
+		rxdesc_ring->pdesc_head = NULL;
+		return;
+	}
+
 	skb_head->protocol = eth_type_trans(skb_head, dev);
 
 	/* Send packet up the stack. */
@@ -315,6 +332,53 @@ static void edma_rx_handle_nr_frags(stru
 	edma_rx_process_last_segment(rxdesc_ring, rxdesc_pri, skb);
 }
 
+/* A flow forwarded to a virtual port is delivered here to be sent out
+ * its bound net device. The descriptor destination info carries the
+ * VP port id; the packet arrives already NAT'd and rewritten, so the
+ * complete L2 frame is simply handed to the device transmit path. The
+ * reverse (wireless to wired) direction is not offloaded.
+ *
+ * The vendor receive path dispatches a virtual port the same way: it
+ * reads the destination info of the descriptor and takes it when the
+ * type is a port id and the port is in the virtual range.
+ */
+static bool edma_rx_deliver_vp(struct edma_rxdesc_pri *rxdesc_pri,
+			       struct sk_buff *skb)
+{
+	struct ppe_device *ppe_dev = edma_ctx->ppe_dev;
+	struct net_device *dev;
+	u32 dst_info;
+	int vp;
+
+	if (!ppe_dev->variant->has_vports)
+		return false;
+
+	dst_info = EDMA_RXDESC_DST_INFO_GET(rxdesc_pri);
+	if ((dst_info & EDMA_RXDESC_SRCINFO_TYPE_MASK) !=
+	    EDMA_RXDESC_SRCINFO_TYPE_PORTID)
+		return false;
+
+	vp = dst_info & EDMA_RXDESC_PORTNUM_BITS;
+	if (vp < PPE_VP_PORT_BASE)
+		return false;
+
+	rcu_read_lock();
+	dev = ppe_vp_dev(ppe_dev, vp);
+	if (unlikely(!dev)) {
+		rcu_read_unlock();
+		dev_kfree_skb_any(skb);
+		return true;
+	}
+
+	skb->dev = dev;
+	skb_reset_mac_header(skb);
+	skb->protocol = eth_hdr(skb)->h_proto;
+	dev_queue_xmit(skb);
+	rcu_read_unlock();
+
+	return true;
+}
+
 static bool edma_rx_handle_linear_packets(struct edma_rxdesc_ring *rxdesc_ring,
 					  struct edma_rxdesc_pri *rxdesc_pri,
 					  struct sk_buff *skb)
@@ -369,6 +433,12 @@ send_to_stack:
 	netdev_dbg(skb->dev, "edma_context:%pK, skb:%pK pkt_length:%u\n",
 		   edma_ctx, skb, skb->len);
 
+	/* A packet forwarded to a virtual port is transmitted out its
+	 * bound device instead of being received up the stack.
+	 */
+	if (edma_rx_deliver_vp(rxdesc_pri, skb))
+		return true;
+
 	skb->protocol = eth_type_trans(skb, skb->dev);
 	if (skb->dev->features & NETIF_F_GRO)
 		napi_gro_receive(&rxdesc_ring->napi, skb);
