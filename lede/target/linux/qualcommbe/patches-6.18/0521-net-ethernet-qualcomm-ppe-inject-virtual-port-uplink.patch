From: Kenneth Kasilag <kenneth@kasilag.me>
Date: Mon, 06 Jul 2026 00:00:00 +0000
Subject: [PATCH] net: ethernet: qualcomm: ppe: inject a virtual port's uplink into the PPE

Offload the wireless-to-wired direction. A routed flow's downlink is
already hardware-forwarded to a virtual port; its uplink still runs on
the netfilter software fast path because packets the wireless radio
receives never traverse the PPE. Add the primitive that puts them
there: edma_tx_vp_inject() submits a received frame on a Tx descriptor
ring tagged with the virtual port as its SOURCE, so the PPE runs the
L3 ingress pipeline - flow lookup, NAT, forward-to-WAN - in hardware.

The inject reuses the ordinary port transmit path rather than a
separate one: edma_tx_ring_xmit() gains a source-virtual-port argument
(EDMA_TX_VP_NONE for an ordinary destination-tagged transmit) that, when
set, makes the first descriptor tag word4 with the SOURCE instead of the
destination (a new EDMA_SRC_INFO macro, mirroring the receive
descriptor's SRC_INFO and the destination macro) and omit the CPU-bypass
service code, so the PPE routes the frame by a flow entry instead of
forwarding it straight out a port. Everything else - descriptor fill,
DMA map, scatter-gather, endian, and Tx-completion reaping by
edma_tx_complete() - is shared with the port path. The source-tag layout
is taken from the vendor descriptor fill; NAT checksum fixup is done by
the flow action.

The PPE has no dedicated virtual-port Tx ring - the ring pool is fully
assigned to the physical ports - so the inject carries the frame on a
running physical port's ring. Any port's ring reaches the PPE (the
descriptor's source tag and the flow entry decide egress, not the ring),
and requiring the port to be up guarantees its Tx-completion NAPI is
active to reap the frame. The inject takes that port's per-CPU Tx queue
lock, so it serialises against the port's own transmits on the ring
exactly as the stack does around ndo_start_xmit; that lock, not any
CPU-pinning assumption, is what makes the shared ring safe. If no port
is up it returns -ENETDOWN and the caller keeps the frame.

Nothing calls the primitive yet - the wireless receive interception that
drives it follows - so this is dormant on its own.

Signed-off-by: Kenneth Kasilag <kenneth@kasilag.me>
---
--- a/drivers/net/ethernet/qualcomm/ppe/edma_port.c
+++ b/drivers/net/ethernet/qualcomm/ppe/edma_port.c
@@ -218,7 +218,7 @@ static netdev_tx_t edma_port_xmit(struct
 	result = edma_tx_gso_segment(skb, dev, &segs);
 	if (likely(result == EDMA_TX_GSO_NOT_NEEDED)) {
 		/* Transmit the packet. */
-		ret = edma_tx_ring_xmit(dev, skb, txdesc_ring, stats);
+		ret = edma_tx_ring_xmit(dev, skb, txdesc_ring, stats, EDMA_TX_VP_NONE);
 
 		if (unlikely(ret == EDMA_TX_FAIL_NO_DESC)) {
 			if (likely(!edma_ctx->tx_requeue_stop)) {
@@ -260,7 +260,7 @@ static netdev_tx_t edma_port_xmit(struct
 		segs = segs->next;
 
 		/* Transmit the packet. */
-		ret = edma_tx_ring_xmit(dev, skb, txdesc_ring, stats);
+		ret = edma_tx_ring_xmit(dev, skb, txdesc_ring, stats, EDMA_TX_VP_NONE);
 		if (unlikely(ret != EDMA_TX_OK)) {
 			dev_kfree_skb_any(skb);
 			u64_stats_update_begin(&stats->syncp);
--- a/drivers/net/ethernet/qualcomm/ppe/edma_tx.c
+++ b/drivers/net/ethernet/qualcomm/ppe/edma_tx.c
@@ -388,7 +388,7 @@ static u32 edma_tx_skb_nr_frags(struct e
 
 static void edma_tx_fill_desc(struct edma_port_priv *port_priv,
 				 struct edma_txdesc_pri *txd, struct sk_buff *skb,
-	struct edma_port_tx_stats *stats)
+	struct edma_port_tx_stats *stats, int src_vp)
 {
 	struct ppe_port *port = port_priv->ppe_port;
 	int port_id = port->port_id;
@@ -427,6 +427,17 @@ static void edma_tx_fill_desc(struct edm
 		}
 	}
 
+	/* A virtual-port inject tags the SOURCE with the virtual port and
+	 * carries no bypass service code, so the PPE runs the L3 ingress
+	 * pipeline (flow lookup, NAT) and routes the frame by a flow entry
+	 * instead of forwarding it straight out a destination port. This is
+	 * the wireless-to-wired uplink; see edma_tx_vp_inject().
+	 */
+	if (src_vp >= 0) {
+		EDMA_SRC_INFO_SET(txd, src_vp);
+		return;
+	}
+
 	/* Set destination information in the descriptor. */
 	EDMA_TXDESC_SERVICE_CODE_SET(txd, PPE_EDMA_SC_BYPASS_ID);
 
@@ -458,7 +469,8 @@ static void edma_tx_fill_desc(struct edm
 static struct edma_txdesc_pri *edma_tx_skb_first_desc(struct edma_port_priv *port_priv,
 						      struct edma_txdesc_ring *txdesc_ring,
 						      struct sk_buff *skb, u32 *hw_next_to_use,
-						      struct edma_port_tx_stats *stats)
+						      struct edma_port_tx_stats *stats,
+						      int src_vp)
 {
 	struct ppe_device *ppe_dev = edma_ctx->ppe_dev;
 	struct edma_txdesc_pri *txd = NULL;
@@ -480,7 +492,7 @@ static struct edma_txdesc_pri *edma_tx_s
 
 	EDMA_TXDESC_BUFFER_ADDR_SET(txd, buff_addr);
 	EDMA_TXDESC_POOL_ID_SET(txd, 0);
-	edma_tx_fill_desc(port_priv, txd, skb, stats);
+	edma_tx_fill_desc(port_priv, txd, skb, stats, src_vp);
 
 	/* Set packet length in the descriptor. */
 	EDMA_TXDESC_DATA_LEN_SET(txd, buf_len);
@@ -696,7 +708,7 @@ static u32 edma_tx_avail_desc(struct edm
  */
 enum edma_tx_status edma_tx_ring_xmit(struct net_device *netdev,
 				      struct sk_buff *skb, struct edma_txdesc_ring *txdesc_ring,
-				struct edma_port_tx_stats *stats)
+				struct edma_port_tx_stats *stats, int src_vp)
 {
 	struct edma_txdesc_stats *txdesc_stats = &txdesc_ring->txdesc_stats;
 	struct edma_port_priv *port_priv = netdev_priv(netdev);
@@ -731,7 +743,7 @@ enum edma_tx_status edma_tx_ring_xmit(st
 	 */
 	if (likely(!skb_is_nonlinear(skb))) {
 		txdesc = edma_tx_skb_first_desc(port_priv, txdesc_ring, skb,
-						&hw_next_to_use, stats);
+						&hw_next_to_use, stats, src_vp);
 		if (unlikely(!txdesc)) {
 			netdev_dbg(netdev, "No descriptor available for ring %d\n",
 				   txdesc_ring->id);
@@ -779,7 +791,7 @@ enum edma_tx_status edma_tx_ring_xmit(st
 		}
 
 		txdesc = edma_tx_skb_first_desc(port_priv, txdesc_ring, skb,
-						&hw_next_to_use, stats);
+						&hw_next_to_use, stats, src_vp);
 		if (unlikely(!txdesc)) {
 			netdev_dbg(netdev, "No non-linear descriptor available for ring %d\n",
 				   txdesc_ring->id);
@@ -828,3 +840,73 @@ enum edma_tx_status edma_tx_ring_xmit(st
 
 	return EDMA_TX_OK;
 }
+
+/**
+ * edma_tx_vp_inject - Inject a received packet into the PPE as a virtual port.
+ * @vp_id: Source virtual port to tag the frame with.
+ * @skb: Socket buffer to inject.
+ *
+ * Push a packet the wireless driver received into the PPE tagged with @vp_id
+ * as its source, so the hardware runs the L3 ingress pipeline - flow lookup,
+ * NAT and forward-to-WAN - instead of the netfilter software fast path. This
+ * is the wireless-to-wired uplink counterpart of the routed downlink delivery
+ * (edma_rx_deliver_vp()).
+ *
+ * The frame rides the ordinary port transmit path (edma_tx_ring_xmit with a
+ * source virtual port), so it inherits that path's descriptor fill, DMA map,
+ * scatter-gather handling and Tx-completion reaping. The PPE has no dedicated
+ * virtual-port Tx ring (the ring pool is fully assigned to the physical
+ * ports), so the inject carries the frame on a running physical port's ring:
+ * any port's ring reaches the PPE - the descriptor's source tag and the flow
+ * entry decide egress, not the ring - and a *running* port guarantees its
+ * Tx-completion NAPI is active to reap the frame. It takes that port's
+ * per-CPU Tx queue lock so the inject serialises against the port's own
+ * transmits on the same ring exactly as the stack does around ndo_start_xmit;
+ * this is the correctness anchor, not any CPU-pinning assumption.
+ *
+ * Runs from the wireless receive softirq. Return 0 on success (the skb is
+ * freed at Tx completion), a negative error code on failure (the caller still
+ * owns the skb): -ENETDOWN if no physical port is up to carry the inject.
+ */
+int edma_tx_vp_inject(u32 vp_id, struct sk_buff *skb)
+{
+	struct edma_hw_info *hw_info = edma_ctx->hw_info;
+	struct edma_port_priv *port_priv;
+	struct edma_txdesc_ring *txdesc_ring;
+	struct edma_port_tx_stats *stats;
+	struct net_device *dev = NULL;
+	struct netdev_queue *txq;
+	enum edma_tx_status ret;
+	u32 skbq;
+	int i, cpu;
+
+	/* Carry the inject on any running physical port: its ring reaches the
+	 * PPE and its Tx-completion NAPI is active to reap the frame.
+	 */
+	for (i = 0; i < hw_info->max_ports; i++) {
+		struct net_device *cand = edma_ctx->netdev_arr[i];
+
+		if (cand && netif_running(cand)) {
+			dev = cand;
+			break;
+		}
+	}
+	if (unlikely(!dev))
+		return -ENETDOWN;
+
+	port_priv = netdev_priv(dev);
+	cpu = smp_processor_id();
+	skbq = cpu & (num_possible_cpus() - 1);
+	txdesc_ring = port_priv->txr_map[skbq];
+	stats = this_cpu_ptr(port_priv->pcpu_stats.tx_stats);
+	txq = netdev_get_tx_queue(dev, skbq);
+
+	/* Serialise against the carrier port's own transmits on this ring,
+	 * exactly as the stack serialises ndo_start_xmit.
+	 */
+	__netif_tx_lock(txq, cpu);
+	ret = edma_tx_ring_xmit(dev, skb, txdesc_ring, stats, vp_id);
+	__netif_tx_unlock(txq);
+
+	return ret == EDMA_TX_OK ? 0 : -EBUSY;
+}
--- a/drivers/net/ethernet/qualcomm/ppe/edma_tx.h
+++ b/drivers/net/ethernet/qualcomm/ppe/edma_tx.h
@@ -53,6 +53,35 @@
 	(EDMA_DST_PORT_TYPE_SET(EDMA_DST_PORT_BITMAP_TYPE) | \
 	 EDMA_DST_PORT_ID_SET(x)))
 
+/* A virtual-port inject tags the frame's SOURCE (not its destination) with
+ * the virtual port, so the PPE runs the L3 ingress pipeline (flow lookup and
+ * NAT) and routes the packet in hardware instead of forwarding it straight
+ * out a destination port. word4 carries the source the same way the receive
+ * descriptor's SRC_INFO does: type 2 in bits 12..15, port in bits 0..11. The
+ * vendor descriptor fill also leaves a dst type-2 marker with no port (the
+ * routing result overrides the destination); reproduce it so the layout is
+ * byte-for-byte what the hardware expects.
+ */
+#define EDMA_SRC_PORT_TYPE		2
+#define EDMA_SRC_PORT_TYPE_SHIFT	12
+#define EDMA_SRC_PORT_TYPE_MASK		(0xf << EDMA_SRC_PORT_TYPE_SHIFT)
+#define EDMA_SRC_PORT_ID_SHIFT		0
+#define EDMA_SRC_PORT_ID_MASK		(0xfff << EDMA_SRC_PORT_ID_SHIFT)
+
+#define EDMA_SRC_PORT_TYPE_SET(x)	(((x) << EDMA_SRC_PORT_TYPE_SHIFT) & \
+							EDMA_SRC_PORT_TYPE_MASK)
+#define EDMA_SRC_PORT_ID_SET(x)		(((x) << EDMA_SRC_PORT_ID_SHIFT) & \
+							EDMA_SRC_PORT_ID_MASK)
+#define EDMA_SRC_INFO_SET(desc, x)	((desc)->word4 |= \
+	(EDMA_DST_PORT_TYPE_SET(EDMA_DST_PORT_TYPE) | \
+	 EDMA_SRC_PORT_TYPE_SET(EDMA_SRC_PORT_TYPE) | EDMA_SRC_PORT_ID_SET(x)))
+
+/* Passed as the source virtual port to edma_tx_ring_xmit() for an ordinary
+ * port transmit (destination-tagged); a value >= 0 requests a virtual-port
+ * inject (source-tagged) instead.
+ */
+#define EDMA_TX_VP_NONE			(-1)
+
 #define EDMA_TXDESC_TSO_ENABLE_MASK		BIT(24)
 #define EDMA_TXDESC_TSO_ENABLE_SET(desc, x)	((desc)->word5 |= \
 				FIELD_PREP(EDMA_TXDESC_TSO_ENABLE_MASK, x))
@@ -303,7 +332,8 @@ extern int edma_tx_mitigation_pkt_cnt;
 enum edma_tx_status edma_tx_ring_xmit(struct net_device *netdev,
 				      struct sk_buff *skb,
 			       struct edma_txdesc_ring *txdesc_ring,
-			       struct edma_port_tx_stats *stats);
+			       struct edma_port_tx_stats *stats, int src_vp);
+int edma_tx_vp_inject(u32 vp_id, struct sk_buff *skb);
 u32 edma_tx_complete(u32 work_to_do,
 		     struct edma_txcmpl_ring *txcmpl_ring);
 irqreturn_t edma_tx_handle_irq(int irq, void *ctx);
